{
  "name": "guardrail-sim",
  "description": "Policy simulation engine for AI agent pricing governance. Test your AI pricing policies before they cost you millions.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r --filter @guardrail-sim/policy-engine --filter @guardrail-sim/mcp-server --filter @guardrail-sim/insights test:coverage",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "quality": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:boundaries",
    "test:boundaries": "node --test tests/test-workspace-boundaries.ts",
    "security:check": "bash scripts/security-check.sh",
    "security:check:strict": "bash scripts/security-check.sh --strict",
    "audit:security": "pnpm audit --audit-level=high",
    "audit:deps": "pnpm outdated || true",
    "demo": "node --experimental-strip-types examples/simulation-demo/index.ts",
    "docs:dev": "pnpm --filter guardrail-sim-website dev",
    "docs:build": "pnpm --filter guardrail-sim-website build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write",
      "bash scripts/security-check.sh"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "jsonpath-plus": ">=10.3.0",
      "react": "19.0.3",
      "react-dom": "19.0.3"
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
